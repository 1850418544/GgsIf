# ========================================
#  环境变量配置示例文件
#  使用方法:
#    1) 复制此文件为 .env:   cp .env.example .env
#    2) 修改 .env 中的值以匹配您的环境
#    3) 程序会自动读取 .env 中的配置
# ========================================

# -------- API 基础配置 --------
# 被测试接口的基础地址（不含接口路径）
API_BASE_URL=https://pehss.sfrtlce.cn/service-boss

# 请求超时时间（秒）
API_TIMEOUT=30

# -------- 测试账号配置 --------
# 登录接口使用的测试账号
TEST_USERNAME=fan
TEST_PASSWORD=fan123

# -------- 企业微信通知配置 --------
# 是否启用企业微信通知 (true/false)
# 设为 false 即可关闭通知，无需修改其他项
SEND_WECHAT_NOTIFICATION=false

# 企业微信机器人 Webhook 地址
# 示例: https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
WECHAT_WEBHOOK_URL=

# -------- 邮件通知配置 --------
# 是否启用邮件通知 (true/false)
# 设为 false 即可关闭通知，无需修改其他项
SEND_EMAIL_NOTIFICATION=false

# SMTP 服务器配置（以 QQ 邮箱为例）
# 不同邮箱的 SMTP 配置参考:
#   QQ邮箱:   smtp.qq.com, 端口465, 使用授权码
#   163邮箱:  smtp.163.com, 端口465, 使用授权码
#   Gmail:    smtp.gmail.com, 端口465, 使用App Password
SMTP_HOST=smtp.qq.com
SMTP_PORT=465

# 发件人邮箱（完整邮箱地址）
SMTP_USER=your_email@qq.com

# 邮箱授权码（注意：不是登录密码，需要在邮箱设置中开启SMTP并获取授权码）
SMTP_PASS=your_email_auth_code

# 发件人显示名称（收件人看到的发件人名称）
SMTP_FROM_NAME=API自动化测试

# 收件人邮箱（支持多个，用逗号分隔）
# 示例: test@example.com, admin@company.com
EMAIL_TO=recipient@example.com

# -------- 其他配置 --------
# 是否生成 Allure 报告 (true/false)
GENERATE_ALLURE_REPORT=true
